FROM node:22-bookworm-slim

RUN corepack enable && corepack prepare pnpm@11.3.0 --activate

WORKDIR /app

# Copy manifests first so Docker can reuse the dependency layer when source
# files change. All workspace manifests are required for pnpm to link packages.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json .npmrc ./
COPY apps/backend/package.json apps/backend/package.json
COPY apps/web/package.json apps/web/package.json
COPY apps/mobile/package.json apps/mobile/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json

RUN pnpm install --frozen-lockfile

COPY apps/backend apps/backend
COPY packages/shared-types packages/shared-types

RUN pnpm --filter @trend/shared-types build && pnpm --filter backend build

EXPOSE 4000

CMD ["pnpm", "--filter", "backend", "start"]
