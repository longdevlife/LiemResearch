{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo",
    "test:mongo": "tsx scripts/test-mongo.ts",
    "mongo:preflight": "tsx scripts/mongo-preflight.ts",
    "mongo:vector-smoke": "tsx scripts/mongo-vector-smoke.ts",
    "mongo:discover-search-indexes": "tsx scripts/mongo-search-index-discovery.ts",
    "mongo:ensure-paper-text-index": "tsx scripts/ensure-paper-text-index.ts",
    "mongo:ensure-paper-vector-index": "tsx scripts/ensure-paper-vector-index.ts",
    "mongo:ensure-paper-cohort-index": "tsx scripts/ensure-paper-cohort-index.ts",
    "mongo:migration-inventory": "tsx scripts/mongo-migration-inventory.ts",
    "mongo:migration-source-databases": "tsx scripts/mongo-migration-source-databases.ts",
    "mongo:migration-verify": "tsx scripts/mongo-migration-verify.ts",
    "mongo:migration-paper-overlap": "tsx scripts/mongo-migration-paper-overlap.ts",
    "mongo:migration-copy": "tsx scripts/mongo-migration-copy.ts",
    "corpus:stats": "tsx scripts/corpus-stats.ts",
    "gemini:probe": "tsx scripts/probe-gemini.ts",
    "report:once": "tsx scripts/run-report-once.ts",
    "seed:providers": "tsx scripts/seed-providers.ts",
    "db:purge-sources": "tsx scripts/purge-source-records.ts",
    "quality:recompute": "tsx scripts/recompute-quality.ts",
    "score:recompute": "tsx scripts/recompute-scores.ts",
    "references:backfill": "tsx scripts/backfill-references.ts",
    "openalex:backfill-metadata": "tsx scripts/backfill-openalex-metadata.ts",
    "openalex:backfill-workflow-status": "tsx scripts/backfill-openalex-workflow-status.ts",
    "promote-admin": "tsx scripts/promote-admin.ts",
    "sync:once": "tsx scripts/run-sync-once.ts",
    "embed:once": "tsx scripts/run-embed-once.ts",
    "paper-analysis:once": "tsx scripts/run-paper-analysis-once.ts",
    "worker:sync": "tsx src/workers/sync.worker.ts",
    "worker:openalex-ingest": "tsx src/workers/openalex-ingest.worker.ts",
    "worker:corpus-validation": "tsx src/workers/corpus-validation.worker.ts",
    "worker:embedding": "tsx src/workers/embedding.worker.ts",
    "worker:paper-analysis": "tsx src/workers/paper-analysis.worker.ts",
    "worker:report": "tsx src/workers/report.worker.ts",
    "worker:gaps": "tsx src/workers/gaps.worker.ts",
    "worker:notifications": "tsx src/workers/notification.worker.ts",
    "dev:check": "tsx scripts/check-dev-deps.ts",
    "dev:all": "pnpm dev:check && concurrently --kill-others-on-fail -n api,report,gaps,notif,embed,analysis,validate -c blue,magenta,yellow,green,cyan,white,gray \"pnpm dev\" \"pnpm worker:report\" \"pnpm worker:gaps\" \"pnpm worker:notifications\" \"pnpm worker:embedding\" \"pnpm worker:paper-analysis\" \"pnpm worker:corpus-validation\"",
    "dev:all+ingest": "pnpm dev:check && concurrently --kill-others-on-fail -n api,report,gaps,notif,embed,analysis,validate,ingest -c blue,magenta,yellow,green,cyan,white,gray,red \"pnpm dev\" \"pnpm worker:report\" \"pnpm worker:gaps\" \"pnpm worker:notifications\" \"pnpm worker:embedding\" \"pnpm worker:paper-analysis\" \"pnpm worker:corpus-validation\" \"pnpm worker:openalex-ingest\"",
    "dev:all+sync": "pnpm dev:check && concurrently --kill-others-on-fail -n api,report,gaps,notif,embed,analysis,sync -c blue,magenta,yellow,green,cyan,white,red \"pnpm dev\" \"pnpm worker:report\" \"pnpm worker:gaps\" \"pnpm worker:notifications\" \"pnpm worker:embedding\" \"pnpm worker:paper-analysis\" \"pnpm worker:sync\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@trend/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.1.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
