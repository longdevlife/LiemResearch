NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Core services
MONGODB_URI=mongodb://localhost:27017/publication_trend
# Migration scripts only. Leave empty in deployed API/worker environments.
# Set this locally to the old database URI while rehearsing a verified cutover.
MIGRATION_SOURCE_MONGODB_URI=
# Optional override when the copied source URI defaults to `test`.
MIGRATION_SOURCE_DATABASE=
REDIS_URL=redis://localhost:6379

# PDF storage
# local = save PDFs to ./uploads for development.
# r2 = save PDFs to Cloudflare R2 through the S3-compatible API.
STORAGE_PROVIDER=local
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_SIGNED_URL_TTL_SECONDS=300

# Auth
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# AI providers
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3.1-flash-lite
GEMINI_MODEL_DEEP=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768

# Project Chat local LLM option
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
CHAT_MAX_PER_HOUR=40
TEAM_CHAT_MAX_PER_MINUTE=20
CHAT_CONTEXT_PAPERS=12
CHAT_HISTORY_TURNS=6
CHAT_MAX_PROMPT_CHARS=12000
CHAT_CACHE_TTL_SECONDS=604800
CHAT_ABSTRACT_MAX_CHARS=800

# Academic providers
OPENALEX_MAILTO=
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=

# Sync and workers
SYNC_CRON=0 2 * * *
SYNC_BATCH_SIZE=100
SYNC_MAX_PAGES_PER_RUN=10
SYNC_STORE_RAW_METADATA=false
# Million-scale OpenAlex campaign worker (explicitly started through admin API).
OPENALEX_INGEST_LEASE_SECONDS=180
OPENALEX_INGEST_CONCURRENCY=1
EMBED_CRON=0 3 * * *
EMBED_BATCH_SIZE=100
EMBED_MAX_PAPERS_PER_RUN=1000
PAPER_ANALYSIS_CRON=0 4 * * *
PAPER_ANALYSIS_BATCH_SIZE=25
PAPER_ANALYSIS_MAX_PAPERS_PER_RUN=100
PAPER_ANALYSIS_MAX_OUTPUT_TOKENS=1024

# Reports, gaps, compare, and search intelligence
REPORT_TOP_K=8
REPORT_MAX_PENDING_PER_USER=2
REPORT_MAX_PER_HOUR=10
REPORT_MAX_OUTPUT_TOKENS=8192
GAPS_TOP_K=6
GAPS_MAX_PER_HOUR=10
GAPS_MAX_OUTPUT_TOKENS=2048
GAP_SCARCE_ABS=5
GAP_SCARCE_PCT=0.02
GAP_PARENT_RISING_MIN=0
COMPARE_MAX_PAPERS=4
COMPARE_PROMPT_VERSION=compare-v2
DEEP_ANALYSIS_MAX_TURNS=5
DEEP_ANALYSIS_MAX_OUTPUT_TOKENS=8192
SEARCH_FILTER_POOL=200
RERANK_CANDIDATES=20
RERANK_MAX_PER_HOUR=30
QUALITY_EVAL_MAX_PER_HOUR=20
DIRECTIONS_MAX_PER_HOUR=20

# Dev/demo only. Never enable in production.
SYNC_ADMIN_BYPASS=false
INITIAL_USER_CREDITS=1000
