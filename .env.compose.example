# Copy to .env.compose. This file is safe to commit; .env.compose is ignored.
# Generate unique JWT secrets, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

MONGO_ROOT_USERNAME=trend_admin
MONGO_ROOT_PASSWORD=replace-with-a-strong-url-safe-password
# Same password as MONGO_ROOT_PASSWORD, URL-encoded for the backend URI.
# Example: pa#ss becomes pa%23ss.
MONGO_ROOT_PASSWORD_URI=replace-with-url-encoded-mongo-password

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-at-least-32-random-characters

# Required for AI features. Replace before using report, gaps, rerank, analysis,
# embedding, or project AI chat.
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Required only when the OpenAlex million-scale campaign worker is enabled.
# OpenAlex now requires a free API key for new API requests.
OPENALEX_API_KEY=
OPENALEX_MAILTO=your-team-email@example.com

# Browser requests go through the Nginx web container by default.
VITE_API_BASE=/api/v1

PORT=4000
LOG_LEVEL=info
STORAGE_PROVIDER=local
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LLM_PROVIDER=gemini

# Paper Detail translation only. Keep disabled unless the Compose translation
# profile (or another LibreTranslate instance) is running.
TRANSLATION_PROVIDER=disabled
LIBRETRANSLATE_API_KEY=
TRANSLATION_TIMEOUT_MS=15000
TRANSLATION_MAX_PER_HOUR=30

# Optional Mongo Express credentials. It is exposed only with --profile tools.
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=replace-with-a-strong-password
